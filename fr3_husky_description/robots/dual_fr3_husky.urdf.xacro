<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fr3">
    <xacro:include filename="$(find franka_description)/robots/common/franka_multi_robot.xacro"/>
    <xacro:include filename="$(find husky_description)/urdf/husky_macro.urdf.xacro" />

    <!-- ============================================================= -->
    <!-- Should an end-effector be mounted at the flange? -->
    <xacro:arg name="hand" default="true" />

    <!-- Should self-collision be enabled? -->
    <xacro:arg name="with_sc" default="false" />

    <!-- Is the robot being controlled with ros2_control?" -->
    <xacro:arg name="ros2_control" default="false" />

    <xacro:arg name="use_mujoco" default="false" />

    <!-- Should a fake hardware be used? -->
    <xacro:arg name="use_fake_hardware" default="false" />

    <!-- Should fake sensors be used? -->
    <xacro:arg name="fake_sensor_commands" default="false" />

    <!-- Use franka hand finger joint as fixed? -->
    <xacro:arg name="fix_finger" default="false"/>

    <!-- Add virtual joint? -->
    <xacro:arg name="virtual_joint" default="false"/>

    <!-- Assume Husky as two wheel mobile? (use only for pinocchio, not ros2_control) -->
    <xacro:arg name="as_two_wheels" default="false"/>
    <!-- ============================================================= -->

    <xacro:arg name="robot_ips" default="['172.16.5.5','172.16.6.6']" />
    <xacro:property name="robot_ips_list" value="${$(arg robot_ips)}" />
    <xacro:property name="robot_ips_str" value="${' '.join(robot_ips_list)}" />

    <xacro:property name="arm_ids_str" value="fr3 fr3" />
    <xacro:property name="robot_prefixes_list" value="${['left','right']}" />
    <xacro:property name="robot_prefixes_str" value="${' '.join(robot_prefixes_list)}" />

    <xacro:property name="xyzs_str"
                    value="${'0.345 0.215 0.26;0.345 -0.215 0.26'}" />
    <xacro:property name="rpys_str"
                    value="${'0 0 0.523598776;0 0 -0.523598776'}" />

    <!-- Virtual -->
    <xacro:if value="$(arg virtual_joint)">
        <link name="world"/>

        <joint name="world_to_vx" type="fixed">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <parent link="world"/>
            <child  link="v_x_link"/>
        </joint>

        <link name="v_x_link" />

        <joint name="v_x_joint" type="prismatic">
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <parent link="v_x_link"/>
            <child link="v_y_link"/>
            <axis xyz= "1 0 0"/>
            <limit effort="1000.0" lower="-10000.0" upper="10000.0" velocity="10000.0"/>
        </joint>

        <link name="v_y_link" />

        <joint name="v_y_joint" type="prismatic">
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <parent link="v_y_link"/>
            <child link="v_t_link"/>
            <axis xyz= "0 1 0"/>
            <limit effort="1000.0" lower="-10000.0" upper="10000.0" velocity="10000.0"/>
        </joint>

        <link name="v_t_link" />

        <joint name="v_t_joint" type="revolute">
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <parent link="v_t_link"/>
            <child link="base_link"/>
            <axis rpy="0 0 0" xyz="0 0 ${0.1651 - 0.03282}"/>
            <limit effort="1000.0" lower="-6.24" upper="6.24" velocity="10000.0"/>
        </joint>
    </xacro:if>

    <!-- Husky -->
    <xacro:husky prefix="" as_two_wheels="$(arg as_two_wheels)"/>

    <link name="top_structure_link">
        <inertial>
            <origin rpy="0 0 0" xyz="-0.108 0 0.252"/>
            <mass value="36.436"/>
            <inertia ixx="6.35" ixy="0.001" ixz="1.711" iyy="7.648" iyz="-0.004" izz="3.775"/>
        </inertial>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fr3_husky_description/meshes/ROAS_structure.stl"/>
            </geometry>
            <material name="medium_grey">
                <color rgba="0.6 0.6 0.6 1.0"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0.006"/>
            <geometry>
                <box size="0.90 0.65 0.012"/>
            </geometry>
        </collision>
        <collision>
            <origin rpy="0 0 0" xyz="-0.28 0 0.65"/>
            <geometry>
                <box size="0.32 0.56 1.3"/>
            </geometry>
        </collision>
    </link>

    <joint name="top_structure_joint" type="fixed">
        <parent link="base_link"/>
        <child link="top_structure_link"/>
        <origin rpy="0 0 0" xyz="0 0 0.248"/>
    </joint>


    <joint name="base_joint" type="fixed">
        <parent link="base_link"/>
        <child link="tmp_base"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <xacro:franka_multi_robot
        arm_ids="${arm_ids_str}"
        robot_ips="${robot_ips_str}"
        robot_prefixes="${robot_prefixes_str}"
        xyzs="${xyzs_str}"
        rpys="${rpys_str}"
        joint_limits="${xacro.load_yaml('$(find franka_description)/robots/fr3/joint_limits.yaml')}"
        inertials="${xacro.load_yaml('$(find franka_description)/robots/fr3/inertials.yaml')}"
        kinematics="${xacro.load_yaml('$(find franka_description)/robots/fr3/kinematics.yaml')}"
        accelerometer_config="${xacro.load_yaml('$(find franka_description)/robots/fr3/accelerometers.yaml')}"
        dynamics="${xacro.load_yaml('$(find franka_description)/robots/fr3/dynamics.yaml')}"
        gazebo="false"
        hand="$(arg hand)"
        ee_id="franka_hand"
        special_connection=""
        xyz_ee="0 0 0"
        rpy_ee="0 0 ${-pi/4}"
        tcp_xyz="0 0 0.1034"
        tcp_rpy="0 0 0"
        safety_distance="0.015"
        with_sc="$(arg with_sc)"
        ros2_control="$(arg ros2_control)"
        use_mujoco="$(arg use_mujoco)"
        use_fake_hardware="$(arg use_fake_hardware)"
        fake_sensor_commands="$(arg fake_sensor_commands)"
        gazebo_effort="false"
        connected_to="tmp_base"
        fix_finger="$(arg fix_finger)"
    />

</robot>
