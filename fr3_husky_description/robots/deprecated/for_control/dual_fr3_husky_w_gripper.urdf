<?xml version="1.0" ?>
<robot name="dual_fr3_husky">
  <link name="world"/>

  <!-- Virtual -->
  <joint name="world_to_vx" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child  link="v_x_link"/>
  </joint>
  <link name="v_x_link" />
  <joint name="v_x_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="v_x_link"/>
      <child link="v_y_link"/>
      <axis xyz= "1 0 0"/>
      <limit effort="1000.0" lower="-10000.0" upper="10000.0" velocity="10000.0"/>
  </joint>
  <link name="v_y_link" />
  <joint name="v_y_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="v_y_link"/>
      <child link="v_t_link"/>
      <axis xyz= "0 1 0"/>
      <limit effort="1000.0" lower="-10000.0" upper="10000.0" velocity="10000.0"/>
  </joint>
  <link name="v_t_link" />
  <joint name="v_t_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="v_t_link"/>
      <child link="base_footprint"/>
      <axis rpy="0 0 0" xyz="0 0 1"/>
      <limit effort="1000.0" lower="-6.24" upper="6.24" velocity="10000.0"/>
  </joint>

  <!-- Mobile Base -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.13228"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://husky_description/meshes/base_link.dae" />
        </geometry>
      </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.061875"/>
      <geometry>
        <box size="0.9874 0.5709 0.12375"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.17562499999999998"/>
      <geometry>
        <box size="0.7899200000000001 0.5709 0.10375"/>
      </geometry>
    </collision>
  </link>

    <link name="top_chassis_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://husky_description/meshes/top_chassis.dae" />
        </geometry>
      </visual>
    </link>

    <joint name="top_chassis_joint" type="fixed">
      <parent link="base_link" />
      <child link="top_chassis_link" />
    </joint>

  <link name="inertial_link">
    <inertial>
      <mass value="46.034"/>
      <origin xyz="-0.00065 -0.085 0.062"/>
      <inertia ixx="0.6022" ixy="-0.02364" ixz="-0.1197" iyy="1.7386" iyz="-0.001544" izz="2.0296"/>
    </inertial>
  </link>

  <joint name="inertial_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="inertial_link"/>
  </joint>

  <link name="left_wheel">
    <inertial>
      <mass value="2.637"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.02467" ixy="0" ixz="0" iyy="0.04411" iyz="0" izz="0.02467"/>
    </inertial>
    <!-- <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1143" radius="0.1651"/>
      </geometry>
    </collision> -->
  </link>

  <!-- Pinocchio takes 'continuous' type as nv=2 -->
  <joint name="left_wheel" type="revolute"> 
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin rpy="0 0 0" xyz="0 0.2775 0.03282"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="100.0" lower="-3.141592" upper="3.141592" velocity="1000"/>
  </joint>

  <link name="right_wheel">
    <inertial>
      <mass value="2.637"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.02467" ixy="0" ixz="0" iyy="0.04411" iyz="0" izz="0.02467"/>
    </inertial>
    <!-- <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1143" radius="0.1651"/>
      </geometry>
    </collision> -->
  </link>

  <joint name="right_wheel" type="revolute">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin rpy="0 0 0" xyz="0 -0.2775 0.03282"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <limit effort="100.0" lower="-3.141592" upper="3.141592" velocity="1000"/>
  </joint>

  <link name="top_structure_link">
    <inertial>
        <origin rpy="0 0 0" xyz="-0.108 0 0.252"/>
        <mass value="36.436"/>
        <inertia ixx="6.35" ixy="0.001" ixz="1.711" iyy="7.648" iyz="-0.004" izz="3.775"/>
    </inertial>
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <mesh filename="package://fr3_husky_description/meshes/ROAS_structure.stl"/>
        </geometry>
        <material name="medium_grey">
            <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.006"/>
      <geometry>
        <box size="0.85 0.65 0.012"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="-0.28 0 0.65"/>
      <geometry>
        <box size="0.32 0.56 1.3"/>
      </geometry>
    </collision>
  </link>
  <joint name="top_structure_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_structure_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.248"/>
  </joint>

