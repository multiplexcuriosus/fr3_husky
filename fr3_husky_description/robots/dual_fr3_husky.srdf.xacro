    <disable_collisions link1="left_fr3_link1" link2="right_fr3_link1" reason="Never"/>
    <disable_collisions link1="left_fr3_link1" link2="right_fr3_link2" reason="Never"/>
    <disable_collisions link1="left_fr3_link2" link2="right_fr3_link0" reason="Never"/>
    <disable_collisions link1="left_fr3_link2" link2="right_fr3_link1" reason="Never"/>
    <disable_collisions link1="left_fr3_link2" link2="right_fr3_link2" reason="Never"/>
    <disable_collisions link1="left_fr3_link3" link2="right_fr3_link0" reason="Never"/>

    <xacro:if value="$(arg with_sc)"> <!-- if mobile  & is sc-->

        <!-- left link - base -->
        <disable_collisions link1="left_fr3_link5" link2="front_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link6" link2="front_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link7" link2="front_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link5" link2="front_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link6" link2="front_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link7" link2="front_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link4" link2="top_structure_link" reason="User"/>
        <disable_collisions link1="left_fr3_link5" link2="base_link" reason="User"/>
        <disable_collisions link1="left_fr3_link5" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link5" link2="top_structure_link" reason="User"/>
        <disable_collisions link1="left_fr3_link6" link2="base_link" reason="User"/>
        <disable_collisions link1="left_fr3_link6" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link6" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link6" link2="top_structure_link" reason="User"/>
        <disable_collisions link1="left_fr3_link7" link2="base_link" reason="User"/>
        <disable_collisions link1="left_fr3_link7" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link7" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="left_fr3_link7" link2="top_structure_link" reason="User"/>

        <!-- left link sc - base -->
        <disable_collisions link1="left_fr3_link0_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link4_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link4_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="top_structure_link" reason="Default"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="base_link" reason="Default"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="top_structure_link" reason="Default"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="top_structure_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="top_structure_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link4_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link4_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link4_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="left_fr3_link4_sc" link2="top_structure_link" reason="Never"/>
        <disable_collisions link1="left_fr3_link5_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>

        <!-- right link - base -->
        <disable_collisions link1="right_fr3_link5" link2="front_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link6" link2="front_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link7" link2="front_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link5" link2="front_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link6" link2="front_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link7" link2="front_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link5" link2="base_link" reason="User"/>
        <disable_collisions link1="right_fr3_link6" link2="base_link" reason="User"/>
        <disable_collisions link1="right_fr3_link7" link2="base_link" reason="User"/>
        <disable_collisions link1="right_fr3_link6" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link7" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link5" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link6" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link7" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
        <disable_collisions link1="right_fr3_link4" link2="top_structure_link" reason="User"/>
        <disable_collisions link1="right_fr3_link5" link2="top_structure_link" reason="User"/>
        <disable_collisions link1="right_fr3_link6" link2="top_structure_link" reason="User"/>
        <disable_collisions link1="right_fr3_link7" link2="top_structure_link" reason="User"/>

        <!-- right link sc - base -->
        <disable_collisions link1="right_fr3_link0_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link1_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link2_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link3_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link4_sc" link2="front_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link0_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link1_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link2_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link3_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link4_sc" link2="front_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link0_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="right_fr3_link1_sc" link2="base_link" reason="Default"/>
        <disable_collisions link1="right_fr3_link2_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="right_fr3_link3_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="right_fr3_link4_sc" link2="base_link" reason="Never"/>
        <disable_collisions link1="right_fr3_link0_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link1_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link2_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link3_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link4_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link5_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link6_sc" link2="rear_left_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link0_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link1_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link2_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link3_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link4_sc" link2="rear_right_wheel${wheel_suffix}" reason="Never"/>
        <disable_collisions link1="right_fr3_link0_sc" link2="top_structure_link" reason="Default"/>
        <disable_collisions link1="right_fr3_link1_sc" link2="top_structure_link" reason="Default"/>
        <disable_collisions link1="right_fr3_link2_sc" link2="top_structure_link" reason="Never"/>
        <disable_collisions link1="right_fr3_link3_sc" link2="top_structure_link" reason="Never"/>
        <disable_collisions link1="right_fr3_link4_sc" link2="top_structure_link" reason="Never"/>

        <!-- left link sc - right link sc -->
        <disable_collisions link1="left_fr3_link0_sc" link2="right_fr3_link0_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="right_fr3_link1_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="right_fr3_link2_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link0_sc" link2="right_fr3_link3_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="right_fr3_link0_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="right_fr3_link1_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="right_fr3_link2_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link1_sc" link2="right_fr3_link3_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="right_fr3_link0_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="right_fr3_link1_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link2_sc" link2="right_fr3_link2_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="right_fr3_link0_sc" reason="Never"/>
        <disable_collisions link1="left_fr3_link3_sc" link2="right_fr3_link1_sc" reason="Never"/>


        <xacro:if value="$(arg hand)"> <!-- if mobile  & is sc & is hand-->

            <!-- left hand - base -->
            <disable_collisions link1="left_fr3_hand" link2="front_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_leftfinger" link2="front_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_rightfinger" link2="front_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_hand" link2="front_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_leftfinger" link2="front_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_rightfinger" link2="front_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_hand" link2="base_link" reason="User"/>
            <disable_collisions link1="left_fr3_hand" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_hand" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_hand" link2="top_structure_link" reason="User"/>
            <disable_collisions link1="left_fr3_leftfinger" link2="base_link" reason="User"/>
            <disable_collisions link1="left_fr3_leftfinger" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_leftfinger" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_leftfinger" link2="top_structure_link" reason="User"/>
            <disable_collisions link1="left_fr3_rightfinger" link2="base_link" reason="User"/>
            <disable_collisions link1="left_fr3_rightfinger" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_rightfinger" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="left_fr3_rightfinger" link2="top_structure_link" reason="User"/>

            <!-- right hand - base -->
            <disable_collisions link1="right_fr3_hand" link2="front_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_leftfinger" link2="front_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_rightfinger" link2="front_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_hand" link2="front_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_leftfinger" link2="front_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_rightfinger" link2="front_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_hand" link2="base_link" reason="User"/>
            <disable_collisions link1="right_fr3_leftfinger" link2="base_link" reason="User"/>
            <disable_collisions link1="right_fr3_rightfinger" link2="base_link" reason="User"/>
            <disable_collisions link1="right_fr3_hand" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_leftfinger" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_rightfinger" link2="rear_left_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_hand" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_leftfinger" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_rightfinger" link2="rear_right_wheel${wheel_suffix}" reason="User"/>
            <disable_collisions link1="right_fr3_hand" link2="top_structure_link" reason="User"/>
            <disable_collisions link1="right_fr3_leftfinger" link2="top_structure_link" reason="User"/>
            <disable_collisions link1="right_fr3_rightfinger" link2="top_structure_link" reason="User"/>
        </xacro:if> 
    </xacro:if>
    
    <group name="dual_fr3_arm">
        <joint name="left_fr3_joint1"/>
        <joint name="left_fr3_joint2"/>
        <joint name="left_fr3_joint3"/>
        <joint name="left_fr3_joint4"/>
        <joint name="left_fr3_joint5"/>
        <joint name="left_fr3_joint6"/>
        <joint name="left_fr3_joint7"/>
        <joint name="right_fr3_joint1"/>
        <joint name="right_fr3_joint2"/>
        <joint name="right_fr3_joint3"/>
        <joint name="right_fr3_joint4"/>
        <joint name="right_fr3_joint5"/>
        <joint name="right_fr3_joint6"/>
        <joint name="right_fr3_joint7"/>
    </group>

     <group_state name="ready" group="dual_fr3_arm">
      <joint name="left_fr3_joint1" value="0"/>
      <joint name="left_fr3_joint2" value="${-pi/4}"/>
      <joint name="left_fr3_joint3" value="0"/>
      <joint name="left_fr3_joint4" value="${-3*pi/4}"/>
      <joint name="left_fr3_joint5" value="0"/>
      <joint name="left_fr3_joint6" value="${pi/2}"/>
      <joint name="left_fr3_joint7" value="${pi/4}"/>
      <joint name="right_fr3_joint1" value="0"/>
      <joint name="right_fr3_joint2" value="${-pi/4}"/>
      <joint name="right_fr3_joint3" value="0"/>
      <joint name="right_fr3_joint4" value="${-3*pi/4}"/>
      <joint name="right_fr3_joint5" value="0"/>
      <joint name="right_fr3_joint6" value="${pi/2}"/>
      <joint name="right_fr3_joint7" value="${pi/4}"/>
    </group_state>
    <group_state name="extended" group="dual_fr3_arm">
      <joint name="left_fr3_joint1" value="0"/>
      <joint name="left_fr3_joint2" value="0"/>
      <joint name="left_fr3_joint3" value="0"/>
      <joint name="left_fr3_joint4" value="-0.1"/>
      <joint name="left_fr3_joint5" value="0"/>
      <joint name="left_fr3_joint6" value="${pi/2}"/>
      <joint name="left_fr3_joint7" value="${pi/4}"/>
      <joint name="right_fr3_joint1" value="0"/>
      <joint name="right_fr3_joint2" value="0"/>
      <joint name="right_fr3_joint3" value="0"/>
      <joint name="right_fr3_joint4" value="-0.1"/>
      <joint name="right_fr3_joint5" value="0"/>
      <joint name="right_fr3_joint6" value="${pi/2}"/>
      <joint name="right_fr3_joint7" value="${pi/4}"/>
    </group_state>

</robot>
