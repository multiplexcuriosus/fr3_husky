<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fr3">

    <xacro:include filename="$(find franka_description)/robots/common/franka_arm.srdf.xacro"/>
    <xacro:include filename="$(find fr3_husky_description)/robots/husky_base.srdf.xacro"/>

    <!-- ============================================================= -->

    <!-- Should an end-effector be mounted at the flange? -->
    <xacro:arg name="hand" default="true" />

    <!-- Should self-collision be enabled? -->
    <xacro:arg name="with_sc" default="false" />

    <!-- Assume Husky as two wheel mobile? (use only for pinocchio, not ros2_control) -->
    <xacro:arg name="as_two_wheels" default="false"/>
    <!-- ============================================================= -->

    <xacro:property name="as_two_wheels_val" value="$(arg as_two_wheels)"/>
    <xacro:property name="wheel_suffix"
                    value="${'_dummy' if str(as_two_wheels_val).lower() == 'true' else ''}"/>


    <xacro:franka_arm_srdf arm_id="fr3"
                           hand="$(arg hand)"
                           ee_id="franka_hand"
                           no_prefix="false"
                           arm_prefix="left_">
    </xacro:franka_arm_srdf>

    <xacro:franka_arm_srdf arm_id="fr3"
                           hand="$(arg hand)"
                           ee_id="franka_hand"
                           no_prefix="false"
                           arm_prefix="right_">
    </xacro:franka_arm_srdf>

    <xacro:if value="$(arg with_sc)"> <!-- if sc -->

        <!-- left link - left link -->
        <disable_collisions link1="left_fr3_link0" link2="left_fr3_link5" reason="User"/>
        <disable_collisions link1="left_fr3_link0" link2="left_fr3_link6" reason="User"/>
        <disable_collisions link1="left_fr3_link0" link2="left_fr3_link7" reason="User"/>
        <disable_collisions link1="left_fr3_link1" link2="left_fr3_link5" reason="User"/>
        <disable_collisions link1="left_fr3_link1" link2="left_fr3_link6" reason="User"/>
        <disable_collisions link1="left_fr3_link1" link2="left_fr3_link7" reason="User"/>
        <disable_collisions link1="left_fr3_link2" link2="left_fr3_link5" reason="User"/>
        <disable_collisions link1="left_fr3_link2" link2="left_fr3_link6" reason="User"/>
        <disable_collisions link1="left_fr3_link2" link2="left_fr3_link7" reason="User"/>

        <!-- left link - left link sc -->
        <disable_collisions link1="left_fr3_link0" link2="left_fr3_link0_sc" reason="Adjacent"/>
        <disable_collisions link1="left_fr3_link0" link2="left_fr3_link1_sc" reason="Default"/>
        <disable_collisions link1="left_fr3_link0" link2="left_fr3_link2_sc" reason="Never"/>
